<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OrreForge.App.ViewModels"
             x:Class="OrreForge.App.Views.IsoExplorerView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="TextBox.LegacyIsoSearch">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3,3,3,0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBox.LegacyIsoSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyIsoSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="Border.LegacyIsoPanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyIsoLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.LegacyIsoHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyIsoButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyIsoButton:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,10,360"
          Width="570"
          Height="400"
          Background="#303030">
        <Border Grid.Column="0" Background="#000000">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyIsoSearch"
                         Text="{Binding IsoSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Visible"
                              Background="Transparent">
                    <ItemsControl ItemsSource="{Binding IsoFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:IsoFileEntryViewModel">
                                <Border PointerPressed="IsoFilePointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="30"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="{Binding SelectionBorderBrush}"
                                        BorderThickness="{Binding SelectionBorderThickness}"
                                        Opacity="{Binding Alpha}">
                                    <TextBlock Text="{Binding Name}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding TextBrush}"
                                               FontSize="14"
                                               Margin="8,0"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="2"
                Width="360"
                Height="400"
                Background="#303030">
            <Border Classes="LegacyIsoPanel"
                    Canvas.Left="0"
                    Canvas.Top="10"
                    Width="350"
                    Height="380">
                <Canvas Width="350" Height="380">
                    <TextBlock Classes="LegacyIsoLabel"
                               Text="{Binding SelectedIsoFileName}"
                               Canvas.Left="18"
                               Canvas.Top="10"
                               Width="149"
                               Height="16"/>
                    <TextBlock Classes="LegacyIsoLabel"
                               Text="{Binding SelectedIsoFileSize}"
                               Canvas.Left="183"
                               Canvas.Top="10"
                               Width="149"
                               Height="16"/>

                    <Button Classes="LegacyIsoButton"
                            Canvas.Left="13"
                            Canvas.Top="51"
                            Width="144"
                            Height="30"
                            Content="Export and decode"
                            Command="{Binding ExportAndDecodeSelectedIsoFileCommand}"/>
                    <Button Classes="LegacyIsoButton"
                            Canvas.Left="193"
                            Canvas.Top="51"
                            Width="144"
                            Height="30"
                            Content="Encode and import"
                            Command="{Binding ImportSelectedIsoFileCommand}"/>
                    <Button Classes="LegacyIsoButton"
                            Canvas.Left="13"
                            Canvas.Top="91"
                            Width="144"
                            Height="24"
                            Content="Export"
                            Command="{Binding QuickExportSelectedIsoFileCommand}"/>
                    <Button Classes="LegacyIsoButton"
                            Canvas.Left="193"
                            Canvas.Top="91"
                            Width="144"
                            Height="24"
                            Content="Import"
                            Command="{Binding ImportSelectedIsoFileCommand}"/>
                    <Button Classes="LegacyIsoButton"
                            Canvas.Left="13"
                            Canvas.Top="121"
                            Width="144"
                            Height="24"
                            Content="Decode only"
                            Command="{Binding DecodeSelectedIsoFileCommand}"/>
                    <Button Classes="LegacyIsoButton"
                            Canvas.Left="193"
                            Canvas.Top="121"
                            Width="144"
                            Height="24"
                            Content="Encode only"
                            Command="{Binding EncodeSelectedIsoFileCommand}"/>
                    <Button Classes="LegacyIsoButton"
                            Canvas.Left="128"
                            Canvas.Top="161"
                            Width="94"
                            Height="24"
                            Content="Delete"
                            Command="{Binding DeleteSelectedIsoFileCommand}"/>

                    <TextBlock Classes="LegacyIsoHeader"
                               Text="Files"
                               Canvas.Left="8"
                               Canvas.Top="206"
                               Width="334"
                               Height="20"/>
                    <ScrollViewer Canvas.Left="10"
                                  Canvas.Top="226"
                                  Width="330"
                                  Height="144"
                                  VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="Transparent">
                        <TextBlock Text="{Binding IsoExplorerFilesText}"
                                   Foreground="#E6E6E6"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Canvas>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
