<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OrreForge.App.ViewModels"
             x:Class="OrreForge.App.Views.PokemonStatsEditorView"
             x:DataType="vm:MainWindowViewModel"
             FontFamily="Arial"
             Background="#F0F0FC">
    <UserControl.Styles>
        <Style Selector="Button.LegacyIsoButton">
            <Setter Property="Background" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#B8B8B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyStatsField">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C0C0C8"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.LegacyStatsField">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C0C0C8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.LegacyStatsLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="250,*">
        <Border Grid.Column="0"
                Background="#000000"
                BorderBrush="#C0C0C8"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBox Text="{Binding PokemonStatsSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search Pokemon"
                         Height="28"
                         Margin="8,6"
                         Padding="8,3"
                         FontSize="12"
                         Background="#FFFFFF"
                         Foreground="#000000"
                         BorderBrush="#808080"
                         BorderThickness="1"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PokemonStatsEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PokemonStatsEntryViewModel">
                                <Border PointerPressed="PokemonStatsPointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}">
                                    <Grid ColumnDefinitions="50,*"
                                          ClipToBounds="True">
                                        <Image Grid.ColumnSpan="2"
                                               Source="{Binding TypeImage}"
                                               Stretch="Fill"
                                               Opacity="{Binding TypeImageOpacity}"/>
                                        <Image Source="{Binding FaceImage}"
                                               Width="50"
                                               Height="50"
                                               Stretch="Uniform"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RowText}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#000000"
                                                   TextWrapping="NoWrap"
                                                   TextAlignment="Center"
                                                   MaxLines="1"
                                                   Margin="4,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              RowDefinitions="*,30"
              Margin="18"
              Background="#FFFFFF">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid DataContext="{Binding SelectedPokemonStatsDetail}"
                      x:CompileBindings="False"
                      Width="900"
                      Margin="0"
                      RowDefinitions="86,Auto,Auto"
                      ColumnDefinitions="230,230,230,190"
                      RowSpacing="10"
                      ColumnSpacing="10">
                    <Border Grid.ColumnSpan="4"
                            Background="#FFFFFF"
                            BorderBrush="#C0C0C8"
                            BorderThickness="1"
                            Padding="10">
                        <Grid ColumnDefinitions="64,180,120,120,160,*"
                              ColumnSpacing="10">
                            <Border Width="64"
                                    Height="64"
                                    Background="#F0F0FC"
                                    BorderBrush="#000000"
                                    BorderThickness="1">
                                <Image Source="{Binding FaceImage}"
                                       Stretch="Uniform"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#000000"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding NationalIndexText}"
                                           Classes="LegacyStatsLabel"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                <TextBlock Text="{Binding IndexText}"
                                           Classes="LegacyStatsLabel"/>
                                <TextBlock Text="{Binding HexText}"
                                           Classes="LegacyStatsLabel"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                <TextBlock Text="Name ID"
                                           Classes="LegacyStatsLabel"
                                           HorizontalAlignment="Center"/>
                                <TextBox Classes="LegacyStatsField"
                                         Text="{Binding NameId, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="4"
                                       Text="{Binding StartOffsetText}"
                                       Classes="LegacyStatsLabel"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5"
                                       Text="{Binding BaseStatTotal, StringFormat='Total: {0}'}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#000000"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#FFFFFF"
                            BorderBrush="#C0C0C8"
                            BorderThickness="1"
                            Padding="10">
                        <Grid RowDefinitions="Auto,24,24,24,24,24,24"
                              ColumnDefinitions="80,*"
                              RowSpacing="5"
                              ColumnSpacing="8">
                            <TextBlock Grid.ColumnSpan="2"
                                       Text="Base Stats"
                                       FontWeight="Bold"
                                       Foreground="#000000"/>
                            <TextBlock Grid.Row="1" Text="HP" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding Hp, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="2" Text="Attack" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding Attack, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="3" Text="Defense" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding Defense, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Text="Sp. Atk" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding SpecialAttack, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="5" Text="Sp. Def" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding SpecialDefense, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="6" Text="Speed" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding Speed, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Background="#FFFFFF"
                            BorderBrush="#C0C0C8"
                            BorderThickness="1"
                            Padding="10">
                        <Grid RowDefinitions="Auto,24,24,24,24,24,24"
                              ColumnDefinitions="80,*"
                              RowSpacing="5"
                              ColumnSpacing="8">
                            <TextBlock Grid.ColumnSpan="2"
                                       Text="EV Yield"
                                       FontWeight="Bold"
                                       Foreground="#000000"/>
                            <TextBlock Grid.Row="1" Text="HP" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding HpYield, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="2" Text="Attack" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding AttackYield, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="3" Text="Defense" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding DefenseYield, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Text="Sp. Atk" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding SpecialAttackYield, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="5" Text="Sp. Def" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding SpecialDefenseYield, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="6" Text="Speed" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding SpeedYield, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="2"
                            Grid.ColumnSpan="2"
                            Background="#FFFFFF"
                            BorderBrush="#C0C0C8"
                            BorderThickness="1"
                            Padding="10">
                        <Grid RowDefinitions="Auto,24,24,24,24,24,24"
                              ColumnDefinitions="92,*,92,*"
                              RowSpacing="5"
                              ColumnSpacing="8">
                            <TextBlock Grid.ColumnSpan="4"
                                       Text="Typing and Abilities"
                                       FontWeight="Bold"
                                       Foreground="#000000"/>
                            <TextBlock Grid.Row="1" Text="Type 1" Classes="LegacyStatsLabel"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Classes="LegacyStatsField" ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding SelectedType1, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Type 2" Classes="LegacyStatsLabel"/>
                            <ComboBox Grid.Row="1" Grid.Column="3" Classes="LegacyStatsField" ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding SelectedType2, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="2" Text="Ability 1" Classes="LegacyStatsLabel"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Classes="LegacyStatsField" ItemsSource="{Binding AbilityOptions}" SelectedItem="{Binding SelectedAbility1, Mode=TwoWay}" MaxDropDownHeight="260"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Ability 2" Classes="LegacyStatsLabel"/>
                            <ComboBox Grid.Row="2" Grid.Column="3" Classes="LegacyStatsField" ItemsSource="{Binding AbilityOptions}" SelectedItem="{Binding SelectedAbility2, Mode=TwoWay}" MaxDropDownHeight="260"/>
                            <TextBlock Grid.Row="3" Text="Catch Rate" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding CatchRate, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Happiness" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="3" Grid.Column="3" Classes="LegacyStatsField" Text="{Binding BaseHappiness, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Text="Base Exp" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Classes="LegacyStatsField" Text="{Binding BaseExp, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="Growth" Classes="LegacyStatsLabel"/>
                            <ComboBox Grid.Row="4" Grid.Column="3" Classes="LegacyStatsField" ItemsSource="{Binding ExpRateOptions}" SelectedItem="{Binding SelectedExpRate, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="5" Text="Gender" Classes="LegacyStatsLabel"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" Classes="LegacyStatsField" ItemsSource="{Binding GenderRatioOptions}" SelectedItem="{Binding SelectedGenderRatio, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="Height (ft)" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="5" Grid.Column="3" Classes="LegacyStatsField" Text="{Binding Height, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" Text="Weight (lbs)" Classes="LegacyStatsLabel"/>
                            <TextBox Grid.Row="6" Grid.Column="3" Classes="LegacyStatsField" Text="{Binding Weight, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="4"
                            Background="#FFFFFF"
                            BorderBrush="#C0C0C8"
                            BorderThickness="1"
                            Padding="10">
                        <Grid RowDefinitions="Auto,24"
                              ColumnDefinitions="90,250,90,250,*"
                              RowSpacing="5"
                              ColumnSpacing="8">
                            <TextBlock Grid.ColumnSpan="5"
                                       Text="Wild Held Items"
                                       FontWeight="Bold"
                                       Foreground="#000000"/>
                            <TextBlock Grid.Row="1" Text="Item 1" Classes="LegacyStatsLabel"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Classes="LegacyStatsField" ItemsSource="{Binding ItemOptions}" SelectedItem="{Binding SelectedHeldItem1, Mode=TwoWay}" MaxDropDownHeight="260"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Item 2" Classes="LegacyStatsLabel"/>
                            <ComboBox Grid.Row="1" Grid.Column="3" Classes="LegacyStatsField" ItemsSource="{Binding ItemOptions}" SelectedItem="{Binding SelectedHeldItem2, Mode=TwoWay}" MaxDropDownHeight="260"/>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Button Grid.Row="1"
                    Classes="LegacyIsoButton"
                    Width="100"
                    Height="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Content="Save"
                    Command="{Binding SavePokemonStatsCommand}"
                    Foreground="#000000"/>
        </Grid>
    </Grid>
</UserControl>
