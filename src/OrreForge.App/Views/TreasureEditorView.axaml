<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:OrreForge.App.Controls"
             xmlns:vm="using:OrreForge.App.ViewModels"
             x:Class="OrreForge.App.Views.TreasureEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="Border.LegacyTreasurePanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyTreasureLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.LegacyTreasureHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureField:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#707070"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureField:focus">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#7D7D7D"/>
        </Style>
        <Style Selector="ComboBox.LegacyTreasureCombo">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyTreasureButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,250"
          Width="450"
          Height="357"
          Background="#303030">
        <Border Grid.Column="0" Background="#222222">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyTreasureSearch"
                         Text="{Binding TreasureSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
                    <ItemsControl ItemsSource="{Binding TreasureEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TreasureEntryViewModel">
                                <Border PointerPressed="TreasurePointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="40"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="{Binding SelectionBorderBrush}"
                                        BorderThickness="{Binding SelectionBorderThickness}">
                                    <StackPanel VerticalAlignment="Center" Margin="6,0">
                                        <TextBlock Text="{Binding RowText}" FontSize="12" Foreground="#000000" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DetailText}" FontSize="10" Foreground="#222222" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="1"
                Width="250"
                Height="357"
                Background="#303030">
            <Border Classes="LegacyTreasurePanel" Canvas.Left="10" Canvas.Top="10" Width="230" Height="295">
                <Canvas>
                    <TextBlock Text="Treasure" Classes="LegacyTreasureHeader" Canvas.Left="10" Canvas.Top="10" Width="210" Height="20"/>
                    <TextBlock Text="Index:" Classes="LegacyTreasureLabel" Canvas.Left="15" Canvas.Top="40" Width="70" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.IndexText, Mode=OneWay}" Classes="LegacyTreasureField" IsReadOnly="True" Canvas.Left="100" Canvas.Top="38" Width="110" Height="20"/>
                    <TextBlock Text="Flag:" Classes="LegacyTreasureLabel" Canvas.Left="15" Canvas.Top="65" Width="70" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.FlagText, Mode=OneWay}" Classes="LegacyTreasureField" IsReadOnly="True" Canvas.Left="100" Canvas.Top="63" Width="110" Height="20"/>
                    <TextBlock Text="Model:" Classes="LegacyTreasureLabel" Canvas.Left="15" Canvas.Top="96" Width="70" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyTreasureCombo" Canvas.Left="100" Canvas.Top="94" Width="110"
                                                    ItemsSource="{Binding SelectedTreasureDetail.ModelOptions}"
                                                    SelectedItem="{Binding SelectedTreasureDetail.SelectedModel, Mode=TwoWay}"/>
                    <TextBlock Text="Item:" Classes="LegacyTreasureLabel" Canvas.Left="15" Canvas.Top="126" Width="70" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyTreasureCombo" Canvas.Left="100" Canvas.Top="124" Width="110"
                                                    ItemsSource="{Binding SelectedTreasureDetail.ItemOptions}"
                                                    SelectedItem="{Binding SelectedTreasureDetail.SelectedItem, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                    <TextBlock Text="Quantity:" Classes="LegacyTreasureLabel" Canvas.Left="15" Canvas.Top="156" Width="70" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.Quantity, Mode=TwoWay}" Classes="LegacyTreasureField" Canvas.Left="100" Canvas.Top="154" Width="110" Height="20"/>
                    <TextBlock Text="Angle:" Classes="LegacyTreasureLabel" Canvas.Left="15" Canvas.Top="186" Width="70" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.Angle, Mode=TwoWay}" Classes="LegacyTreasureField" Canvas.Left="100" Canvas.Top="184" Width="110" Height="20"/>
                    <TextBlock Text="Room:" Classes="LegacyTreasureLabel" Canvas.Left="15" Canvas.Top="216" Width="70" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyTreasureCombo" Canvas.Left="100" Canvas.Top="214" Width="110"
                                                    ItemsSource="{Binding SelectedTreasureDetail.RoomOptions}"
                                                    SelectedItem="{Binding SelectedTreasureDetail.SelectedRoom, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>

                    <TextBlock Text="X" Classes="LegacyTreasureLabel" Canvas.Left="15" Canvas.Top="252" Width="18" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.X, Mode=TwoWay}" Classes="LegacyTreasureField" Canvas.Left="33" Canvas.Top="250" Width="55" Height="20"/>
                    <TextBlock Text="Y" Classes="LegacyTreasureLabel" Canvas.Left="91" Canvas.Top="252" Width="18" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.Y, Mode=TwoWay}" Classes="LegacyTreasureField" Canvas.Left="109" Canvas.Top="250" Width="55" Height="20"/>
                    <TextBlock Text="Z" Classes="LegacyTreasureLabel" Canvas.Left="167" Canvas.Top="252" Width="18" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.Z, Mode=TwoWay}" Classes="LegacyTreasureField" Canvas.Left="185" Canvas.Top="250" Width="35" Height="20"/>
                </Canvas>
            </Border>

            <Button Classes="LegacyTreasureButton"
                    Canvas.Left="65"
                    Canvas.Top="315"
                    Width="120"
                    Height="30"
                    Content="Save"
                    Command="{Binding SaveTreasureCommand}"/>
        </Canvas>
    </Grid>
</UserControl>
