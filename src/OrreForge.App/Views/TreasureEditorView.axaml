<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:OrreForge.App.Controls"
             xmlns:vm="using:OrreForge.App.ViewModels"
             x:Class="OrreForge.App.Views.TreasureEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="Border.LegacyTreasurePanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyTreasureHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureField:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#707070"/>
        </Style>
        <Style Selector="TextBox.LegacyTreasureField:focus">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#7D7D7D"/>
        </Style>
        <Style Selector="ComboBox.LegacyTreasureCombo">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#6A6A6A"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyTreasureButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="198,444"
          Width="642"
          Height="386"
          Background="#303030">
        <Border Grid.Column="0" Background="#222222">
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <ItemsControl ItemsSource="{Binding TreasureEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TreasureEntryViewModel">
                            <Border PointerPressed="TreasurePointerPressed"
                                    Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    Height="40"
                                    Background="{Binding BackgroundBrush}"
                                    BorderBrush="{Binding SelectionBorderBrush}"
                                    BorderThickness="{Binding SelectionBorderThickness}">
                                <StackPanel VerticalAlignment="Center" Margin="5,0">
                                    <TextBlock Text="{Binding RowText}"
                                               FontSize="12"
                                               Foreground="#000000"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding DetailText}"
                                               FontSize="11"
                                               Foreground="#000000"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Canvas Grid.Column="1"
                Width="444"
                Height="386"
                Background="#303030">
            <Border Classes="LegacyTreasurePanel" Canvas.Left="4" Canvas.Top="6" Width="436" Height="348">
                <Canvas>
                    <controls:LegacyPokemonComboBox Classes="LegacyTreasureCombo"
                                                    Canvas.Left="10"
                                                    Canvas.Top="25"
                                                    Width="416"
                                                    ItemsSource="{Binding SelectedTreasureDetail.RoomOptions}"
                                                    SelectedItem="{Binding SelectedTreasureDetail.SelectedRoom, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>

                    <controls:LegacyPokemonComboBox Classes="LegacyTreasureCombo"
                                                    Canvas.Left="10"
                                                    Canvas.Top="85"
                                                    Width="204"
                                                    ItemsSource="{Binding SelectedTreasureDetail.ModelOptions}"
                                                    SelectedItem="{Binding SelectedTreasureDetail.SelectedModel, Mode=TwoWay}"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyTreasureCombo"
                                                    Canvas.Left="224"
                                                    Canvas.Top="85"
                                                    Width="202"
                                                    ItemsSource="{Binding SelectedTreasureDetail.ItemOptions}"
                                                    SelectedItem="{Binding SelectedTreasureDetail.SelectedItem, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>

                    <TextBlock Text="quantity" Classes="LegacyTreasureHeader" Canvas.Left="10" Canvas.Top="140" Width="204" Height="20"/>
                    <TextBlock Text="angle" Classes="LegacyTreasureHeader" Canvas.Left="224" Canvas.Top="140" Width="202" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.Quantity, Mode=TwoWay}"
                             Classes="LegacyTreasureField"
                             Canvas.Left="10"
                             Canvas.Top="162"
                             Width="204"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.Angle, Mode=TwoWay}"
                             Classes="LegacyTreasureField"
                             Canvas.Left="224"
                             Canvas.Top="162"
                             Width="202"/>

                    <TextBlock Text="x" Classes="LegacyTreasureHeader" Canvas.Left="10" Canvas.Top="228" Width="132" Height="20"/>
                    <TextBlock Text="y" Classes="LegacyTreasureHeader" Canvas.Left="152" Canvas.Top="228" Width="132" Height="20"/>
                    <TextBlock Text="z" Classes="LegacyTreasureHeader" Canvas.Left="294" Canvas.Top="228" Width="132" Height="20"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.X, Mode=TwoWay}"
                             Classes="LegacyTreasureField"
                             Canvas.Left="10"
                             Canvas.Top="250"
                             Width="132"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.Y, Mode=TwoWay}"
                             Classes="LegacyTreasureField"
                             Canvas.Left="152"
                             Canvas.Top="250"
                             Width="132"/>
                    <TextBox Text="{Binding SelectedTreasureDetail.Z, Mode=TwoWay}"
                             Classes="LegacyTreasureField"
                             Canvas.Left="294"
                             Canvas.Top="250"
                             Width="132"/>

                    <Button Classes="LegacyTreasureButton"
                            Canvas.Left="158"
                            Canvas.Top="305"
                            Width="120"
                            Height="20"
                            Content="Save"
                            Command="{Binding SaveTreasureCommand}"/>
                </Canvas>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
