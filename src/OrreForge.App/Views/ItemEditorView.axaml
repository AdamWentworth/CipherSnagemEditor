<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:OrreForge.App.Controls"
             xmlns:vm="using:OrreForge.App.ViewModels"
             x:Class="OrreForge.App.Views.ItemEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="Border.LegacyItemPanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyItemLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.LegacyItemHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBox.LegacyItemField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyItemReadout">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.LegacyItemCombo">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyItemButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyItemSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="CheckBox.LegacyItemCheck">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Border Name="LegacyCheckGlyph"
                                Width="15"
                                Height="15"
                                Background="#505050"
                                BorderBrush="#3E3E3E"
                                BorderThickness="1"
                                CornerRadius="3"
                                VerticalAlignment="Center">
                            <Path Name="LegacyCheckMark"
                                  Width="10"
                                  Height="8"
                                  Stretch="Uniform"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  Data="M 1,4 L 4,7 L 9,1"
                                  Opacity="0"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontSize="{TemplateBinding FontSize}"
                                          VerticalAlignment="Center"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="CheckBox.LegacyItemCheck:checked /template/ Border#LegacyCheckGlyph">
            <Setter Property="Background" Value="#0878E7"/>
            <Setter Property="BorderBrush" Value="#66B4FF"/>
        </Style>
        <Style Selector="CheckBox.LegacyItemCheck:checked /template/ Path#LegacyCheckMark">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,660"
          Width="860"
          Height="480"
          Background="#303030">
        <Border Grid.Column="0"
                Background="#222222">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyItemSearch"
                         Text="{Binding ItemSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Visible">
                    <ItemsControl ItemsSource="{Binding ItemEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ItemEntryViewModel">
                                <Border PointerPressed="ItemPointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="{Binding SelectionBorderBrush}"
                                        BorderThickness="{Binding SelectionBorderThickness}">
                                    <Grid ClipToBounds="True">
                                        <Image Source="{Binding ItemCellImage}"
                                               Stretch="Fill"
                                               Opacity="0.32"/>
                                        <TextBlock Text="{Binding RowText}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#000000"
                                                   TextWrapping="NoWrap"
                                                   TextAlignment="Center"
                                                   MaxLines="1"
                                                   Margin="8,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="1"
                Width="660"
                Height="480"
                Background="#303030">
            <Border Classes="LegacyItemPanel"
                    Canvas.Left="10"
                    Canvas.Top="10"
                    Width="210"
                    Height="190">
                <Canvas>
                    <TextBlock Text="Name:" Classes="LegacyItemLabel" Canvas.Left="8" Canvas.Top="5" Width="79" Height="30"/>
                    <TextBox Text="{Binding SelectedItemDetail.Name, Mode=OneWay}" Classes="LegacyItemField" IsReadOnly="True" Canvas.Left="95" Canvas.Top="5" Width="105"/>
                    <TextBlock Text="Name ID:" Classes="LegacyItemLabel" Canvas.Left="8" Canvas.Top="40" Width="79" Height="30"/>
                    <TextBox Text="{Binding SelectedItemDetail.NameId, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="95" Canvas.Top="40" Width="105"/>
                    <Separator Canvas.Left="10" Canvas.Top="75" Width="190" Height="5"/>
                    <TextBlock Text="Index:" Classes="LegacyItemLabel" Canvas.Left="8" Canvas.Top="85" Width="79" Height="18"/>
                    <TextBox Text="{Binding SelectedItemDetail.IndexText, Mode=OneWay}" Classes="LegacyItemReadout" IsReadOnly="True" Canvas.Left="93" Canvas.Top="85" Width="109"/>
                    <TextBlock Text="Hex:" Classes="LegacyItemLabel" Canvas.Left="8" Canvas.Top="120" Width="79" Height="18"/>
                    <TextBox Text="{Binding SelectedItemDetail.HexText, Mode=OneWay}" Classes="LegacyItemReadout" IsReadOnly="True" Canvas.Left="93" Canvas.Top="120" Width="109"/>
                    <TextBlock Text="Start Offset:" Classes="LegacyItemLabel" Canvas.Left="8" Canvas.Top="155" Width="79" Height="18"/>
                    <TextBox Text="{Binding SelectedItemDetail.StartOffsetText, Mode=OneWay}" Classes="LegacyItemReadout" IsReadOnly="True" Canvas.Left="93" Canvas.Top="155" Width="109"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyItemPanel" Canvas.Left="240" Canvas.Top="10" Width="400" Height="120">
                <Canvas>
                    <TextBlock Text="Description ID" Classes="LegacyItemHeader" Canvas.Left="18" Canvas.Top="10" Width="104" Height="30"/>
                    <TextBox Text="{Binding SelectedItemDetail.DescriptionId, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="130" Canvas.Top="10" Width="80"/>
                    <TextBlock Text="Description" Classes="LegacyItemHeader" Canvas.Left="163" Canvas.Top="50" Width="74" Height="20"/>
                    <TextBox Text="{Binding SelectedItemDetail.Description, Mode=OneWay}" Classes="LegacyItemField" IsReadOnly="True" HorizontalContentAlignment="Center" Canvas.Left="20" Canvas.Top="80" Width="360"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyItemPanel" Canvas.Left="240" Canvas.Top="140" Width="400" Height="60">
                <Canvas>
                    <TextBlock Text="Price" Classes="LegacyItemLabel" Canvas.Left="18" Canvas.Top="15" Width="44" Height="30"/>
                    <TextBox Text="{Binding SelectedItemDetail.Price, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="65" Canvas.Top="15" Width="108"/>
                    <TextBlock Text="Coupon Price" Classes="LegacyItemLabel" Canvas.Left="186" Canvas.Top="15" Width="84" Height="30" TextAlignment="Right"/>
                    <TextBox Text="{Binding SelectedItemDetail.CouponPrice, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="273" Canvas.Top="15" Width="107"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyItemPanel" Canvas.Left="10" Canvas.Top="210" Width="210" Height="80">
                <Canvas>
                    <CheckBox Content="Disposable/Holdable"
                              Classes="LegacyItemCheck"
                              IsChecked="{Binding SelectedItemDetail.CanBeHeld, Mode=TwoWay}"
                              Canvas.Left="18"
                              Canvas.Top="28"
                              Width="174"
                              Height="24"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyItemPanel" Canvas.Left="240" Canvas.Top="210" Width="400" Height="80">
                <Canvas>
                    <TextBlock Text="Parameter" Classes="LegacyItemLabel" Canvas.Left="8" Canvas.Top="30" Width="64" Height="20"/>
                    <TextBox Text="{Binding SelectedItemDetail.Parameter, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="75" Canvas.Top="28" Width="60" Height="20"/>
                    <TextBlock Text="Hold ID" Classes="LegacyItemLabel" Canvas.Left="143" Canvas.Top="30" Width="49" Height="20"/>
                    <TextBox Text="{Binding SelectedItemDetail.HoldItemId, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="195" Canvas.Top="28" Width="60" Height="20"/>
                    <TextBlock Text="Usage ID" Classes="LegacyItemLabel" Canvas.Left="263" Canvas.Top="30" Width="64" Height="20" TextAlignment="Right"/>
                    <TextBox Text="{Binding SelectedItemDetail.InBattleUseId, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="330" Canvas.Top="28" Width="60" Height="20"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyItemPanel" Canvas.Left="10" Canvas.Top="300" Width="210" Height="80">
                <Canvas>
                    <TextBlock Text="Pocket" Classes="LegacyItemLabel" Canvas.Left="18" Canvas.Top="30" Width="54" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyItemCombo" Canvas.Left="78" Canvas.Top="27" Width="125"
                                                    ItemsSource="{Binding SelectedItemDetail.BagSlotOptions}"
                                                    SelectedItem="{Binding SelectedItemDetail.SelectedBagSlot, Mode=TwoWay}"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyItemPanel" Canvas.Left="240" Canvas.Top="300" Width="400" Height="80">
                <Canvas>
                    <TextBlock Text="Friendship" Classes="LegacyItemLabel" Canvas.Left="18" Canvas.Top="30" Width="74" Height="20"/>
                    <TextBox Text="{Binding SelectedItemDetail.Friendship1, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="100" Canvas.Top="28" Width="40" Height="20"/>
                    <TextBox Text="{Binding SelectedItemDetail.Friendship2, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="150" Canvas.Top="28" Width="40" Height="20"/>
                    <TextBox Text="{Binding SelectedItemDetail.Friendship3, Mode=TwoWay}" Classes="LegacyItemField" Canvas.Left="200" Canvas.Top="28" Width="40" Height="20"/>
                    <TextBlock Text="TM"
                               Classes="LegacyItemLabel"
                               IsVisible="{Binding SelectedItemDetail.IsTmVisible}"
                               Canvas.Left="248"
                               Canvas.Top="30"
                               Width="24"
                               Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyItemCombo"
                                                    IsVisible="{Binding SelectedItemDetail.IsTmVisible}"
                                                    Canvas.Left="278"
                                                    Canvas.Top="27"
                                                    Width="105"
                                                    ItemsSource="{Binding SelectedItemDetail.MoveOptions}"
                                                    SelectedItem="{Binding SelectedItemDetail.SelectedTmMove, Mode=TwoWay}"
                                                    MaxDropDownHeight="300"/>
                </Canvas>
            </Border>

            <Button Classes="LegacyItemButton"
                    Canvas.Left="270"
                    Canvas.Top="430"
                    Width="120"
                    Height="30"
                    Content="Save"
                    Command="{Binding SaveItemCommand}"/>
        </Canvas>
    </Grid>
</UserControl>
