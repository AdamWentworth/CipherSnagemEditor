<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OrreForge.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="640"
        d:DesignHeight="504"
        x:Class="OrreForge.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        Width="640"
        Height="504"
        MinWidth="640"
        MinHeight="504"
        MaxWidth="1000"
        MaxHeight="1000"
        WindowDecorations="None"
        FontFamily="Arial"
        Background="#F0F0FC">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.LegacyOpenButton">
            <Setter Property="Background" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#B8B8B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyOpenButton:pointerover">
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>
        <Style Selector="Button.LegacyOpenButton:pressed">
            <Setter Property="Background" Value="#C4C4C4"/>
        </Style>
        <Style Selector="Button.TitleBarButton">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.TitleBarButton:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="#505050"/>
        </Style>
        <Style Selector="Button.TitleBarClose:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="#E81123"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="24,*"
          Background="#F0F0FC">
        <Border Background="#3A3A3A"
                PointerPressed="MainTitleBarPointerPressed">
            <Grid ColumnDefinitions="138,*,138">
                <TextBlock Grid.Column="1"
                           Text="Colosseum Tool"
                           Foreground="#CFCFCF"
                           FontSize="12"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Classes="TitleBarButton"
                            Content="-"
                            Click="MainMinimizeClick"/>
                    <Button Classes="TitleBarButton"
                            Content="□"
                            Click="MainZoomClick"/>
                    <Button Classes="TitleBarButton TitleBarClose"
                            Content="X"
                            Click="MainCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="200,*"
              Background="#F0F0FC">
            <Border Background="#000000"
                    BorderBrush="#111111"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tools}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ToolEntryViewModel">
                                <Border PointerPressed="ToolPointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="50"
                                        Margin="0"
                                        Background="{Binding CurrentFallbackBrush}">
                                    <Grid Height="50"
                                          ClipToBounds="True">
                                        <Border Background="{Binding CurrentFallbackBrush}"/>
                                        <Image Source="{Binding CurrentBackgroundImage}"
                                               Stretch="Fill"/>
                                        <TextBlock Text="{Binding Title}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="#000000"
                                                   TextAlignment="Center"
                                                   TextWrapping="NoWrap"
                                                   Margin="8,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1"
                  RowDefinitions="20,*">
                <Border Background="#F0F0FC"
                        BorderBrush="#C0C0C8"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="80,*,80">
                        <TextBlock Grid.Column="1"
                                   Text="Log"
                                   Foreground="#000000"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="2"
                                Classes="LegacyOpenButton"
                                Content="Open..."
                                Click="OpenFileClick"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#B8F0FF"
                        BorderBrush="#80ACFF"
                        BorderThickness="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="8">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="#000000"
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
