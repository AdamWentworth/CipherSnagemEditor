<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OrreForge.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="OrreForge.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        MinWidth="900"
        MinHeight="620"
        FontFamily="Arial"
        Background="#F0F0FC">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <Border Background="#FFFFFF"
                BorderBrush="#C0C0C8"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                    <Button Content="Open..." Click="OpenFileClick" MinWidth="92" Foreground="#000000"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="Colosseum Tool"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#000000"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ProjectTitle}"
                               Foreground="#000000"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="220,*"
              RowDefinitions="*">
            <Border Grid.Column="0"
                    Background="#000000"
                    BorderBrush="#C0C0C8"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Tools"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"
                               Margin="10,8,10,6"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tools}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ToolEntryViewModel">
                                    <Button Click="ToolClick"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="0"
                                            Margin="0"
                                            MinHeight="50"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#000000">
                                        <Grid ColumnDefinitions="34,*"
                                              MinHeight="50">
                                            <Image Grid.ColumnSpan="2"
                                                   Source="{Binding CurrentBackgroundAsset}"
                                                   Stretch="Fill"/>
                                            <TextBlock Text="{Binding Index}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="#000000"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="#000000"
                                                       TextWrapping="NoWrap"
                                                       Margin="4,0,8,0"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,150"
                  Margin="18">
                <Border Background="#FFFFFF"
                        BorderBrush="#C0C0C8"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding WorkspaceStatus}"
                                   FontSize="13"
                                   Foreground="#000000"
                                   TextWrapping="Wrap"/>
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsBusy}"
                                     Height="4"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="#FFFFFF"
                        BorderBrush="#C0C0C8"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="18"
                        Margin="0,14,0,14">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="{Binding SelectedTool.Title}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#000000"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding SelectedToolDetail}"
                                   Foreground="#000000"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="#B8F0FF"
                        BorderBrush="#80ACFF"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="#000000"
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
