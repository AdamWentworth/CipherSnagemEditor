<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OrreForge.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="OrreForge.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        MinWidth="900"
        MinHeight="620"
        FontFamily="Arial"
        Background="#F0F0FC">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <Border Background="#FFFFFF"
                BorderBrush="#C0C0C8"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                    <Button Content="Home"
                            Command="{Binding ReturnHomeCommand}"
                            IsVisible="{Binding ShowIsoExplorer}"
                            MinWidth="76"
                            Foreground="#000000"/>
                    <Button Content="Open..." Click="OpenFileClick" MinWidth="92" Foreground="#000000"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="Colosseum Tool"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#000000"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ProjectTitle}"
                               Foreground="#000000"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="220,*"
              RowDefinitions="*">
            <Border Grid.Column="0"
                    Background="#000000"
                    BorderBrush="#C0C0C8"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{Binding LeftPanelTitle}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"
                               Margin="10,8,10,6"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding Tools}"
                                          IsVisible="{Binding ShowHomeTools}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ToolEntryViewModel">
                                        <Border PointerPressed="ToolPointerPressed"
                                                Cursor="Hand"
                                                HorizontalAlignment="Stretch"
                                                MinHeight="50"
                                                Margin="0"
                                                Background="{Binding CurrentFallbackBrush}">
                                            <Grid MinHeight="50">
                                                <Border Background="{Binding CurrentFallbackBrush}"/>
                                                <Image Source="{Binding CurrentBackgroundImage}"
                                                       Stretch="Fill"/>
                                                <TextBlock Text="{Binding Title}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="#000000"
                                                           TextWrapping="NoWrap"
                                                           Margin="8,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding IsoFiles}"
                                          IsVisible="{Binding ShowIsoExplorer}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:IsoFileEntryViewModel">
                                        <Border PointerPressed="IsoFilePointerPressed"
                                                Cursor="Hand"
                                                MinHeight="30"
                                                Background="{Binding BackgroundBrush}"
                                                BorderBrush="#000000"
                                                BorderThickness="0"
                                                Opacity="{Binding Alpha}">
                                            <TextBlock Text="{Binding Name}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding TextBrush}"
                                                       FontSize="14"
                                                       Margin="8,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,150"
                  Margin="18">
                <Border Background="#FFFFFF"
                        BorderBrush="#C0C0C8"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding WorkspaceStatus}"
                                   FontSize="13"
                                   Foreground="#000000"
                                   TextWrapping="Wrap"/>
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsBusy}"
                                     Height="4"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="#FFFFFF"
                        BorderBrush="#C0C0C8"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="18"
                        Margin="0,14,0,14">
                    <Grid>
                        <Grid RowDefinitions="Auto,Auto,*"
                              IsVisible="{Binding ShowToolPlaceholder}">
                            <TextBlock Text="{Binding SelectedTool.Title}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#000000"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding SelectedToolDetail}"
                                       Foreground="#000000"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0"/>
                        </Grid>

                        <Grid IsVisible="{Binding ShowIsoExplorer}"
                              Width="350"
                              HorizontalAlignment="Left"
                              RowDefinitions="Auto,Auto,Auto,Auto,*">
                            <Grid ColumnDefinitions="*,*"
                                  Margin="0,0,0,26">
                                <TextBlock Text="{Binding SelectedIsoFileName}"
                                           Foreground="#000000"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedIsoFileSize}"
                                           Foreground="#000000"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="18,0,0,0"/>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnDefinitions="*,*"
                                  RowDefinitions="34,30,30"
                                  ColumnSpacing="36"
                                  RowSpacing="6">
                                <Button Content="Export and decode"
                                        Command="{Binding ExportAndDecodeSelectedIsoFileCommand}"
                                        Foreground="#000000"
                                        Height="30"/>
                                <Button Grid.Column="1"
                                        Content="Encode and import"
                                        Command="{Binding ImportSelectedIsoFileCommand}"
                                        Foreground="#000000"
                                        Height="30"/>
                                <Button Grid.Row="1"
                                        Content="Export"
                                        Command="{Binding QuickExportSelectedIsoFileCommand}"
                                        Foreground="#000000"
                                        Height="24"/>
                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        Content="Import"
                                        Command="{Binding ImportSelectedIsoFileCommand}"
                                        Foreground="#000000"
                                        Height="24"/>
                                <Button Grid.Row="2"
                                        Content="Decode only"
                                        Command="{Binding DecodeSelectedIsoFileCommand}"
                                        Foreground="#000000"
                                        Height="24"/>
                                <Button Grid.Row="2"
                                        Grid.Column="1"
                                        Content="Encode only"
                                        Command="{Binding EncodeSelectedIsoFileCommand}"
                                        Foreground="#000000"
                                        Height="24"/>
                            </Grid>

                            <Button Grid.Row="2"
                                    Content="Delete"
                                    IsEnabled="False"
                                    Foreground="#000000"
                                    HorizontalAlignment="Center"
                                    Width="80"
                                    Height="24"
                                    Margin="0,16,0,12"/>

                            <TextBlock Grid.Row="3"
                                       Text="Files"
                                       Foreground="#000000"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,0"/>

                            <ScrollViewer Grid.Row="4"
                                          VerticalScrollBarVisibility="Auto"
                                          Background="Transparent"
                                          Margin="0,4,0,0">
                                <TextBlock Text="{Binding IsoExplorerFilesText}"
                                           Foreground="#000000"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="#B8F0FF"
                        BorderBrush="#80ACFF"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="#000000"
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
