<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:OrreForge.App.Controls"
             xmlns:vm="using:OrreForge.App.ViewModels"
             x:Class="OrreForge.App.Views.MoveEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="Border.LegacyMovePanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyMoveLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.LegacyMoveHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBox.LegacyMoveField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyMoveReadout">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.LegacyMoveCombo">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyMoveButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="CheckBox.LegacyMoveCheck">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Border Name="LegacyCheckGlyph"
                                Width="15"
                                Height="15"
                                Background="#505050"
                                BorderBrush="#3E3E3E"
                                BorderThickness="1"
                                CornerRadius="3"
                                VerticalAlignment="Center">
                            <Path Name="LegacyCheckMark"
                                  Width="10"
                                  Height="8"
                                  Stretch="Uniform"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  Data="M 1,4 L 4,7 L 9,1"
                                  Opacity="0"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontSize="{TemplateBinding FontSize}"
                                          VerticalAlignment="Center"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="CheckBox.LegacyMoveCheck:pointerover /template/ Border#LegacyCheckGlyph">
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="CheckBox.LegacyMoveCheck:checked /template/ Border#LegacyCheckGlyph">
            <Setter Property="Background" Value="#0878E7"/>
            <Setter Property="BorderBrush" Value="#66B4FF"/>
        </Style>
        <Style Selector="CheckBox.LegacyMoveCheck:checked /template/ Path#LegacyCheckMark">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="TextBox.LegacyMoveSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBox.LegacyMoveSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyMoveSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,674"
          Width="874"
          Height="480"
          Background="#303030">
        <Border Grid.Column="0"
                Background="#222222">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyMoveSearch"
                         Text="{Binding MoveSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Visible">
                    <ItemsControl ItemsSource="{Binding MoveEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MoveEntryViewModel">
                                <Border PointerPressed="MovePointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="{Binding SelectionBorderBrush}"
                                        BorderThickness="{Binding SelectionBorderThickness}">
                                    <Grid ClipToBounds="True">
                                        <Image Source="{Binding TypeImage}"
                                               Stretch="Fill"/>
                                        <TextBlock Text="{Binding RowText}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#000000"
                                                   TextWrapping="NoWrap"
                                                   TextAlignment="Center"
                                                   MaxLines="1"
                                                   Margin="8,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="1"
                Width="674"
                Height="480"
                Background="#303030">
            <Border Classes="LegacyMovePanel"
                    Canvas.Left="10"
                    Canvas.Top="10"
                    Width="210"
                    Height="145">
                <Canvas>
                    <TextBlock Text="Name:" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="5" Width="79" Height="30"/>
                    <TextBox Text="{Binding SelectedMoveDetail.Name, Mode=OneWay}" Classes="LegacyMoveField" IsReadOnly="True" Canvas.Left="95" Canvas.Top="5" Width="105"/>
                    <TextBlock Text="Name ID:" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="40" Width="79" Height="30"/>
                    <TextBox Text="{Binding SelectedMoveDetail.NameId, Mode=TwoWay}" Classes="LegacyMoveField" Canvas.Left="95" Canvas.Top="40" Width="105"/>
                    <Separator Canvas.Left="10" Canvas.Top="75" Width="190" Height="5"/>
                    <TextBlock Text="Index:" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="85" Width="79" Height="18"/>
                    <TextBox Text="{Binding SelectedMoveDetail.IndexText, Mode=OneWay}" Classes="LegacyMoveReadout" IsReadOnly="True" Canvas.Left="93" Canvas.Top="85" Width="109"/>
                    <TextBlock Text="Hex:" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="105" Width="79" Height="18"/>
                    <TextBox Text="{Binding SelectedMoveDetail.HexText, Mode=OneWay}" Classes="LegacyMoveReadout" IsReadOnly="True" Canvas.Left="93" Canvas.Top="105" Width="109"/>
                    <TextBlock Text="Start Offset:" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="125" Width="79" Height="18"/>
                    <TextBox Text="{Binding SelectedMoveDetail.StartOffsetText, Mode=OneWay}" Classes="LegacyMoveReadout" IsReadOnly="True" Canvas.Left="93" Canvas.Top="125" Width="109"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyMovePanel" Canvas.Left="230" Canvas.Top="10" Width="434" Height="70">
                <Canvas>
                    <TextBlock Text="Description ID" Classes="LegacyMoveHeader" Canvas.Left="3" Canvas.Top="10" Width="94" Height="20"/>
                    <TextBlock Text="Description" Classes="LegacyMoveHeader" Canvas.Left="98" Canvas.Top="10" Width="333" Height="20"/>
                    <TextBox Text="{Binding SelectedMoveDetail.DescriptionId, Mode=TwoWay}" Classes="LegacyMoveField" Canvas.Left="5" Canvas.Top="35" Width="90"/>
                    <TextBox Text="{Binding SelectedMoveDetail.Description, Mode=OneWay}" Classes="LegacyMoveField" IsReadOnly="True" HorizontalContentAlignment="Center" Canvas.Left="100" Canvas.Top="35" Width="329"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyMovePanel" Canvas.Left="230" Canvas.Top="85" Width="434" Height="70">
                <Canvas>
                    <TextBlock Text="Effect" Classes="LegacyMoveHeader" Canvas.Left="8" Canvas.Top="10" Width="418" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyMoveCombo" Canvas.Left="8" Canvas.Top="34" Width="419"
                                                    ItemsSource="{Binding SelectedMoveDetail.EffectOptions}"
                                                    SelectedItem="{Binding SelectedMoveDetail.SelectedEffect, Mode=TwoWay}"
                                                    MaxDropDownHeight="300"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyMovePanel" Canvas.Left="10" Canvas.Top="165" Width="210" Height="275">
                <Canvas>
                    <TextBlock Text="Type" Classes="LegacyMoveHeader" Canvas.Left="8" Canvas.Top="10" Width="194" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyMoveCombo" Canvas.Left="8" Canvas.Top="31" Width="195"
                                                    ItemsSource="{Binding SelectedMoveDetail.TypeOptions}"
                                                    SelectedItem="{Binding SelectedMoveDetail.SelectedType, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                    <TextBlock Text="Category" Classes="LegacyMoveHeader" Canvas.Left="8" Canvas.Top="62" Width="194" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyMoveCombo" Canvas.Left="8" Canvas.Top="83" Width="195"
                                                    ItemsSource="{Binding SelectedMoveDetail.CategoryOptions}"
                                                    SelectedItem="{Binding SelectedMoveDetail.SelectedCategory, Mode=TwoWay}"/>
                    <TextBlock Text="Targets" Classes="LegacyMoveHeader" Canvas.Left="8" Canvas.Top="114" Width="194" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyMoveCombo" Canvas.Left="8" Canvas.Top="135" Width="195"
                                                    ItemsSource="{Binding SelectedMoveDetail.TargetOptions}"
                                                    SelectedItem="{Binding SelectedMoveDetail.SelectedTarget, Mode=TwoWay}"/>
                    <TextBlock Text="Animation" Classes="LegacyMoveHeader" Canvas.Left="8" Canvas.Top="166" Width="194" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyMoveCombo" Canvas.Left="8" Canvas.Top="187" Width="195"
                                                    ItemsSource="{Binding SelectedMoveDetail.AnimationOptions}"
                                                    SelectedItem="{Binding SelectedMoveDetail.SelectedAnimation, Mode=TwoWay}"
                                                    MaxDropDownHeight="300"/>
                    <TextBlock Text="{Binding SelectedMoveDetail.Animation2Text}" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="213" Width="194" Height="18" TextAlignment="Center"/>
                    <TextBlock Text="Effect Type" Classes="LegacyMoveHeader" Canvas.Left="8" Canvas.Top="231" Width="194" Height="16"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyMoveCombo" Canvas.Left="8" Canvas.Top="248" Width="195"
                                                    ItemsSource="{Binding SelectedMoveDetail.EffectTypeOptions}"
                                                    SelectedItem="{Binding SelectedMoveDetail.SelectedEffectType, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyMovePanel" Canvas.Left="230" Canvas.Top="165" Width="212" Height="275">
                <Canvas>
                    <TextBlock Text="Power" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="25" Width="84" Height="33"/>
                    <TextBox Text="{Binding SelectedMoveDetail.Power, Mode=TwoWay}" Classes="LegacyMoveField" Canvas.Left="100" Canvas.Top="25" Width="102"/>
                    <TextBlock Text="Accuracy" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="73" Width="84" Height="33"/>
                    <TextBox Text="{Binding SelectedMoveDetail.Accuracy, Mode=TwoWay}" Classes="LegacyMoveField" Canvas.Left="100" Canvas.Top="73" Width="102"/>
                    <TextBlock Text="PP" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="121" Width="84" Height="33"/>
                    <TextBox Text="{Binding SelectedMoveDetail.Pp, Mode=TwoWay}" Classes="LegacyMoveField" Canvas.Left="100" Canvas.Top="121" Width="102"/>
                    <TextBlock Text="Priority" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="169" Width="84" Height="33"/>
                    <TextBox Text="{Binding SelectedMoveDetail.Priority, Mode=TwoWay}" Classes="LegacyMoveField" Canvas.Left="100" Canvas.Top="169" Width="102"/>
                    <TextBlock Text="Effect Accuracy" Classes="LegacyMoveLabel" Canvas.Left="8" Canvas.Top="217" Width="84" Height="33"/>
                    <TextBox Text="{Binding SelectedMoveDetail.EffectAccuracy, Mode=TwoWay}" Classes="LegacyMoveField" Canvas.Left="100" Canvas.Top="217" Width="102"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyMovePanel" Canvas.Left="452" Canvas.Top="165" Width="212" Height="275">
                <Canvas>
                    <CheckBox Content="HM" Classes="LegacyMoveCheck" IsChecked="{Binding SelectedMoveDetail.HmFlag, Mode=TwoWay}" Canvas.Left="8" Canvas.Top="33" Width="95" Height="22"/>
                    <CheckBox Content="Protect" Classes="LegacyMoveCheck" IsChecked="{Binding SelectedMoveDetail.ProtectFlag, Mode=TwoWay}" Canvas.Left="109" Canvas.Top="33" Width="95" Height="22"/>
                    <CheckBox Content="Sound" Classes="LegacyMoveCheck" IsChecked="{Binding SelectedMoveDetail.SoundBasedFlag, Mode=TwoWay}" Canvas.Left="8" Canvas.Top="97" Width="95" Height="22"/>
                    <CheckBox Content="Snatch" Classes="LegacyMoveCheck" IsChecked="{Binding SelectedMoveDetail.SnatchFlag, Mode=TwoWay}" Canvas.Left="109" Canvas.Top="97" Width="95" Height="22"/>
                    <CheckBox Content="Contact" Classes="LegacyMoveCheck" IsChecked="{Binding SelectedMoveDetail.ContactFlag, Mode=TwoWay}" Canvas.Left="8" Canvas.Top="161" Width="95" Height="22"/>
                    <CheckBox Content="Magic Coat" Classes="LegacyMoveCheck" IsChecked="{Binding SelectedMoveDetail.MagicCoatFlag, Mode=TwoWay}" Canvas.Left="109" Canvas.Top="161" Width="95" Height="22"/>
                    <CheckBox Content="King's Rock" Classes="LegacyMoveCheck" IsChecked="{Binding SelectedMoveDetail.KingsRockFlag, Mode=TwoWay}" Canvas.Left="8" Canvas.Top="225" Width="95" Height="22"/>
                    <CheckBox Content="Mirror Move" Classes="LegacyMoveCheck" IsChecked="{Binding SelectedMoveDetail.MirrorMoveFlag, Mode=TwoWay}" Canvas.Left="109" Canvas.Top="225" Width="95" Height="22"/>
                </Canvas>
            </Border>

            <Button Classes="LegacyMoveButton"
                    Canvas.Left="281"
                    Canvas.Top="446"
                    Width="112"
                    Height="31"
                    Content="Save"
                    Command="{Binding SaveMoveCommand}"/>
        </Canvas>
    </Grid>
</UserControl>
