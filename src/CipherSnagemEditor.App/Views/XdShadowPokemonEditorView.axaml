<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.XdShadowPokemonEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="TextBox.XdField">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.XdSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBlock.XdLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.XdSave">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,*" Background="#303030">
        <Border Background="#222222" BorderBrush="#111111" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="XdSearch"
                         Text="{Binding XdShadowPokemonSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"/>
                <ListBox Grid.Row="1"
                         Classes="LegacySidebarList"
                         ItemsSource="{Binding XdShadowPokemonEntries}"
                         SelectedItem="{Binding SelectedXdShadowPokemon, Mode=TwoWay}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:XdShadowPokemonEntryViewModel">
                            <Border Height="50"
                                    Cursor="Hand"
                                    Background="{Binding BackgroundBrush}"
                                    BorderBrush="{Binding SelectionBorderBrush}"
                                    BorderThickness="{Binding SelectionBorderThickness}">
                                <Grid ColumnDefinitions="50,*">
                                    <Image Source="{Binding FaceImage}" Width="50" Height="50" Stretch="Uniform"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RowText}"
                                               Foreground="#000000"
                                               FontSize="12"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               MaxLines="2"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="*,32" Margin="10">
            <Border Background="#303030" BorderBrush="#545454" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid ColumnDefinitions="115,*" RowDefinitions="70,28,28,28,28,28,28,28,*" ColumnSpacing="10" RowSpacing="7">
                    <Border Grid.RowSpan="3" Width="88" Height="88" Background="#242424" BorderBrush="#545454" BorderThickness="1" HorizontalAlignment="Center">
                        <Image Source="{Binding SelectedXdShadowPokemon.BodyImage}" Stretch="Uniform"/>
                    </Border>

                    <TextBlock Grid.Column="1" Text="{Binding SelectedXdShadowPokemon.Shadow.SpeciesName}" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Shadow Pokemon" FontSize="12" Foreground="#CFCFCF"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedXdShadowPokemon.RowText}" FontSize="12" Foreground="#CFCFCF"/>

                    <TextBlock Grid.Row="3" Text="Shadow ID:" Classes="XdLabel"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdShadowPokemon.Shadow.Index}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="4" Text="Story PKM:" Classes="XdLabel"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdShadowPokemon.Shadow.StoryPokemonIndex}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="5" Text="Catch Rate:" Classes="XdLabel"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdShadowPokemon.Shadow.CatchRate}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="6" Text="Heart Gauge:" Classes="XdLabel"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdShadowPokemon.Shadow.HeartGauge}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="7" Text="Behavior:" Classes="XdLabel"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdShadowPokemon.Shadow.Aggression, StringFormat='Aggression {0}'}" IsReadOnly="True"/>

                    <Grid Grid.Row="8" Grid.ColumnSpan="2" RowDefinitions="24,*">
                        <TextBlock Text="Shadow Moves" Foreground="#E6E6E6" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="1"
                                 Classes="XdField"
                                 Text="{Binding SelectedXdShadowPokemon.MovesText}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 HorizontalContentAlignment="Left"
                                 VerticalContentAlignment="Top"
                                 Height="82"/>
                    </Grid>
                </Grid>
            </Border>

            <Button Grid.Row="1" Classes="XdSave" Content="Save" Width="100" Height="20" IsEnabled="False" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</UserControl>
