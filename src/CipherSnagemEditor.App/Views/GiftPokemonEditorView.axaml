<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CipherSnagemEditor.App.Controls"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.GiftPokemonEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="Border.LegacyGiftPanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyGiftLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.LegacyGiftHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyGiftField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyGiftField:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#707070"/>
        </Style>
        <Style Selector="TextBox.LegacyGiftField:focus">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#7D7D7D"/>
        </Style>
        <Style Selector="ComboBox.LegacyGiftCombo">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyGiftButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyGiftSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBox.LegacyGiftSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyGiftSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,360"
          Width="560"
          Height="330"
          Background="#303030">
        <Border Grid.Column="0" Background="#222222">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyGiftSearch"
                         Text="{Binding GiftPokemonSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
                    <ItemsControl ItemsSource="{Binding GiftPokemonEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:GiftPokemonEntryViewModel">
                                <Border PointerPressed="GiftPokemonPointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="{Binding SelectionBorderBrush}"
                                        BorderThickness="{Binding SelectionBorderThickness}">
                                    <Grid ColumnDefinitions="52,*" ClipToBounds="True">
                                        <Image Source="{Binding FaceImage}"
                                               Width="48"
                                               Height="48"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RowText}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#000000"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   Margin="2,0,8,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="1"
                Width="360"
                Height="330"
                Background="#303030">
            <Border Classes="LegacyGiftPanel" Canvas.Left="10" Canvas.Top="10" Width="340" Height="270">
                <Canvas>
                    <Image Source="{Binding SelectedGiftPokemonDetail.FaceImage}" Canvas.Left="12" Canvas.Top="12" Width="64" Height="64" Stretch="Uniform"/>
                    <TextBlock Text="Gift" Classes="LegacyGiftLabel" Canvas.Left="88" Canvas.Top="12" Width="60" Height="24"/>
                    <TextBox Text="{Binding SelectedGiftPokemonDetail.GiftType, Mode=OneWay}" Classes="LegacyGiftField" IsReadOnly="True" Canvas.Left="148" Canvas.Top="12" Width="180"/>
                    <TextBlock Text="Pokemon" Classes="LegacyGiftLabel" Canvas.Left="88" Canvas.Top="46" Width="60" Height="24"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="148" Canvas.Top="46" Width="180"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.SpeciesOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.SelectedSpecies, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>

                    <TextBlock Text="Level" Classes="LegacyGiftLabel" Canvas.Left="12" Canvas.Top="90" Width="52" Height="24"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="70" Canvas.Top="90" Width="78"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.LevelOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.Level, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                    <TextBlock Text="Shiny" Classes="LegacyGiftLabel" Canvas.Left="162" Canvas.Top="90" Width="48" Height="24"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="212" Canvas.Top="90" Width="116"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.ShinyOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.SelectedShiny, Mode=TwoWay}"/>

                    <TextBlock Text="Moves" Classes="LegacyGiftHeader" Canvas.Left="12" Canvas.Top="124" Width="316" Height="20"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="12" Canvas.Top="148" Width="152"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.MoveOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.SelectedMove1, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="176" Canvas.Top="148" Width="152"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.MoveOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.SelectedMove2, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="12" Canvas.Top="180" Width="152"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.MoveOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.SelectedMove3, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="176" Canvas.Top="180" Width="152"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.MoveOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.SelectedMove4, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>

                    <TextBlock Text="Gender" Classes="LegacyGiftLabel" Canvas.Left="12" Canvas.Top="218" Width="58" Height="24"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="70" Canvas.Top="218" Width="104"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.GenderOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.SelectedGender, Mode=TwoWay}"/>
                    <TextBlock Text="Nature" Classes="LegacyGiftLabel" Canvas.Left="184" Canvas.Top="218" Width="48" Height="24"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyGiftCombo" Canvas.Left="234" Canvas.Top="218" Width="94"
                                                    ItemsSource="{Binding SelectedGiftPokemonDetail.NatureOptions}"
                                                    SelectedItem="{Binding SelectedGiftPokemonDetail.SelectedNature, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                </Canvas>
            </Border>

            <Button Classes="LegacyGiftButton"
                    Canvas.Left="120"
                    Canvas.Top="290"
                    Width="120"
                    Height="30"
                    Content="Save"
                    Command="{Binding SaveGiftPokemonCommand}"/>
        </Canvas>
    </Grid>
</UserControl>
