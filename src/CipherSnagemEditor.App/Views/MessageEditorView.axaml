<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CipherSnagemEditor.App.Controls"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.MessageEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="Border.LegacyMessagePanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyMessageLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.LegacyMessageHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageField:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#707070"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageField:focus">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#7D7D7D"/>
        </Style>
        <Style Selector="ComboBox.LegacyMessageCombo">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyMessageButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,480"
          Width="680"
          Height="300"
          Background="#303030">
        <Border Grid.Column="0" Background="#222222">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyMessageSearch"
                         Text="{Binding MessageSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
                    <ItemsControl ItemsSource="{Binding MessageStrings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageStringEntryViewModel">
                                <Border PointerPressed="MessageStringPointerPressed"
                                        Cursor="Hand"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="{Binding SelectionBorderBrush}"
                                        BorderThickness="{Binding SelectionBorderThickness}">
                                    <Grid RowDefinitions="18,*" Margin="6,2">
                                        <TextBlock Text="{Binding IdHexText}" FontSize="11" Foreground="#000000" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Preview}" FontSize="11" Foreground="#000000" TextAlignment="Center" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="1"
                Width="480"
                Height="300"
                Background="#303030">
            <Border Classes="LegacyMessagePanel" Canvas.Left="10" Canvas.Top="10" Width="460" Height="58">
                <Canvas>
                    <TextBlock Text="File" Classes="LegacyMessageLabel" Canvas.Left="12" Canvas.Top="18" Width="42" Height="22"/>
                    <controls:LegacyPokemonComboBox Classes="LegacyMessageCombo" Canvas.Left="58" Canvas.Top="17" Width="390"
                                                    ItemsSource="{Binding MessageTables}"
                                                    SelectedItem="{Binding SelectedMessageTable, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>
                </Canvas>
            </Border>

            <Border Classes="LegacyMessagePanel" Canvas.Left="10" Canvas.Top="78" Width="460" Height="168">
                <Canvas>
                    <TextBlock Text="String ID" Classes="LegacyMessageHeader" Canvas.Left="16" Canvas.Top="12" Width="90" Height="20"/>
                    <TextBox Text="{Binding SelectedMessageIdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Classes="LegacyMessageField" Canvas.Left="16" Canvas.Top="38" Width="90" Height="24" HorizontalContentAlignment="Right"/>
                    <TextBlock Text="Description" Classes="LegacyMessageHeader" Canvas.Left="118" Canvas.Top="12" Width="326" Height="20"/>
                    <TextBox Text="{Binding SelectedMessageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Classes="LegacyMessageField" AcceptsReturn="True" TextWrapping="Wrap" Canvas.Left="118" Canvas.Top="38" Width="326" Height="112"/>
                </Canvas>
            </Border>

            <Button Classes="LegacyMessageButton"
                    Canvas.Left="180"
                    Canvas.Top="258"
                    Width="120"
                    Height="30"
                    Content="Save"
                    Command="{Binding SaveMessageCommand}"/>
        </Canvas>
    </Grid>
</UserControl>
