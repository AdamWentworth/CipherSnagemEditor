<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CipherSnagemEditor.App.Controls"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.MessageEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="Border.LegacyMessagePanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyMessageLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.LegacyMessageHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#8A8A8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="CaretBrush" Value="#000000"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageField:pointerover">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#8A8A8A"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageField:focus">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#000000"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5D8DFF"/>
        </Style>
        <Style Selector="ComboBox.LegacyMessageCombo">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyMessageButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyMessageSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,480"
          Width="680"
          Height="300"
          Background="#303030">
        <Border Grid.Column="0" Background="#222222">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyMessageSearch"
                         Text="{Binding MessageSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
                    <ItemsControl ItemsSource="{Binding MessageStrings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageStringEntryViewModel">
                                <Border PointerPressed="MessageStringPointerPressed"
                                        Cursor="Hand"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="#000000"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding RowText}"
                                               FontSize="12"
                                               Foreground="#000000"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxLines="3"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="6,0"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="1"
                Width="480"
                Height="300"
                Background="#303030">
            <controls:LegacyPokemonComboBox Classes="LegacyMessageCombo"
                                            Canvas.Left="113"
                                            Canvas.Top="20"
                                            Width="255"
                                            Height="25"
                                            ItemsSource="{Binding MessageTables}"
                                            SelectedItem="{Binding SelectedMessageTable, Mode=TwoWay}"
                                            MaxDropDownHeight="260"/>

            <TextBlock Text="String ID:" Classes="LegacyMessageLabel" Canvas.Left="18" Canvas.Top="61" Width="64" Height="30"/>
            <TextBox Text="{Binding SelectedMessageIdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Classes="LegacyMessageField"
                     Canvas.Left="100"
                     Canvas.Top="61"
                     Width="130"
                     Height="30"
                     HorizontalContentAlignment="Right"
                     IsReadOnly="{Binding IsMessageEditorReadOnly}"/>

            <TextBox Text="{Binding SelectedMessageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Classes="LegacyMessageField"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Canvas.Left="20"
                     Canvas.Top="111"
                     Width="440"
                     Height="128"
                     IsReadOnly="{Binding IsMessageEditorReadOnly}"/>

            <Button Classes="LegacyMessageButton"
                    Canvas.Left="200"
                    Canvas.Top="255"
                    Width="81"
                    Height="32"
                    Content="Save"
                    Command="{Binding SaveMessageCommand}"/>
        </Canvas>
    </Grid>
</UserControl>
