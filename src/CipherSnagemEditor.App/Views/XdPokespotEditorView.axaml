<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.XdPokespotEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="TextBox.XdField">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.XdPicker">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="Border.XdMiniField">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="TextBlock.XdPickerText">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
        <Style Selector="TextBlock.XdMiniText">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        <Style Selector="TextBox.XdSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBlock.XdLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.XdSave">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,*" Background="#303030">
        <Border Background="#222222" BorderBrush="#111111" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="XdSearch"
                         Text="{Binding XdPokespotSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"/>
                <ListBox Grid.Row="1"
                         Classes="LegacySidebarList"
                         ItemsSource="{Binding XdPokespotEntries}"
                         SelectedItem="{Binding SelectedXdPokespot, Mode=TwoWay}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:XdPokespotEntryViewModel">
                            <Border Height="50"
                                    Cursor="Hand"
                                    Background="{Binding FallbackBrush}"
                                    BorderBrush="{Binding SelectionBorderBrush}"
                                    BorderThickness="{Binding SelectionBorderThickness}">
                                <Grid ColumnDefinitions="50,*" ClipToBounds="True">
                                    <Image Grid.ColumnSpan="2" Source="{Binding TypeImage}" Stretch="Fill" Opacity="{Binding TypeImageOpacity}"/>
                                    <Image Source="{Binding FaceImage}" Width="50" Height="50" Stretch="Uniform"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RowText}"
                                               Foreground="#000000"
                                               FontSize="12"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="10">
            <Border Width="260"
                    Height="340"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#303030"
                    BorderBrush="#545454"
                    BorderThickness="1"
                    CornerRadius="6"
                    ClipToBounds="True">
                <Canvas Width="260" Height="340">
                    <Image Source="{Binding SelectedXdPokespot.BodyImage}"
                           Canvas.Left="80"
                           Canvas.Top="48"
                           Width="100"
                           Height="100"
                           Stretch="Uniform"/>

                    <Border Classes="XdPicker" Canvas.Left="78" Canvas.Top="135" Width="105">
                        <TextBlock Classes="XdPickerText" Text="{Binding SelectedXdPokespot.Encounter.SpeciesName}"/>
                    </Border>

                    <TextBlock Canvas.Left="42" Canvas.Top="180" Width="70" Text="Min" Classes="XdLabel" TextAlignment="Center"/>
                    <TextBlock Canvas.Left="148" Canvas.Top="180" Width="70" Text="Max" Classes="XdLabel" TextAlignment="Center"/>
                    <Border Classes="XdPicker" Canvas.Left="5" Canvas.Top="205" Width="100">
                        <TextBlock Classes="XdPickerText" Text="{Binding SelectedXdPokespot.Encounter.MinLevel, StringFormat='Lv. {0}'}"/>
                    </Border>
                    <Border Classes="XdPicker" Canvas.Left="155" Canvas.Top="205" Width="95">
                        <TextBlock Classes="XdPickerText" Text="{Binding SelectedXdPokespot.Encounter.MaxLevel, StringFormat='Lv. {0}'}"/>
                    </Border>

                    <TextBlock Canvas.Left="5" Canvas.Top="250" Width="105" Text="Encounter Chance" Classes="XdLabel" TextAlignment="Center"/>
                    <TextBlock Canvas.Left="153" Canvas.Top="250" Width="100" Text="Steps Per Snack" Classes="XdLabel" TextAlignment="Center"/>
                    <Border Classes="XdMiniField" Canvas.Left="5" Canvas.Top="275" Width="100">
                        <TextBlock Classes="XdMiniText" Text="{Binding SelectedXdPokespot.Encounter.EncounterPercentage}"/>
                    </Border>
                    <Border Classes="XdMiniField" Canvas.Left="155" Canvas.Top="275" Width="90">
                        <TextBlock Classes="XdMiniText" Text="{Binding SelectedXdPokespot.Encounter.StepsPerSnack}"/>
                    </Border>

                    <Button Classes="XdSave"
                            Content="Save"
                            Width="80"
                            Height="21"
                            IsEnabled="False"
                            Canvas.Left="90"
                            Canvas.Top="306"/>
                </Canvas>
            </Border>
        </Grid>
    </Grid>
</UserControl>
