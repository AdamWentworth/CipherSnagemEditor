<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             xmlns:controls="using:CipherSnagemEditor.App.Controls"
             x:Class="CipherSnagemEditor.App.Views.XdPokespotEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="ComboBox.XdPickerField">
            <Setter Property="Height" Value="20"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="3,0,2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.XdMiniInput">
            <Setter Property="Height" Value="20"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.XdSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBlock.XdLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.XdSave">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,*" Background="#303030">
        <Border Background="#222222" BorderBrush="#111111" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="XdSearch"
                         Text="{Binding XdPokespotSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"/>
                <ListBox Grid.Row="1"
                         Classes="LegacySidebarList"
                         ItemsSource="{Binding XdPokespotEntries}"
                         SelectedItem="{Binding SelectedXdPokespot, Mode=TwoWay}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:XdPokespotEntryViewModel">
                            <Border Height="50"
                                    Cursor="Hand"
                                    Background="{Binding FallbackBrush}"
                                    BorderBrush="{Binding SelectionBorderBrush}"
                                    BorderThickness="{Binding SelectionBorderThickness}">
                                <Grid ColumnDefinitions="50,*" ClipToBounds="True">
                                    <Image Grid.ColumnSpan="2" Source="{Binding TypeImage}" Stretch="Fill" Opacity="{Binding TypeImageOpacity}"/>
                                    <Image Source="{Binding FaceImage}" Width="50" Height="50" Stretch="Uniform"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RowText}"
                                               Foreground="#000000"
                                               FontSize="12"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="10">
            <Border Width="260"
                    Height="340"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#303030"
                    BorderBrush="#545454"
                    BorderThickness="1"
                    CornerRadius="6"
                    ClipToBounds="True">
                <Canvas Width="260" Height="340">
                    <Image DataContext="{Binding SelectedXdPokespot}"
                           Source="{Binding BodyImage}"
                           Classes="PokemonBodyImage"
                           Canvas.Left="80"
                           Canvas.Top="48"
                           Width="100"
                           Height="100"
                           Stretch="Uniform"/>

                    <controls:LegacyPokemonComboBox Classes="XdPickerField"
                                                    Canvas.Left="78"
                                                    Canvas.Top="135"
                                                    Width="105"
                                                    ItemsSource="{Binding SelectedXdPokespot.SpeciesOptions}"
                                                    SelectedItem="{Binding SelectedXdPokespot.SelectedSpecies, Mode=TwoWay}"
                                                    MaxDropDownHeight="260"/>

                    <TextBlock Canvas.Left="42" Canvas.Top="180" Width="70" Text="Min" Classes="XdLabel" TextAlignment="Center"/>
                    <TextBlock Canvas.Left="148" Canvas.Top="180" Width="70" Text="Max" Classes="XdLabel" TextAlignment="Center"/>
                    <controls:LegacyPokemonComboBox Classes="XdPickerField"
                                                    Canvas.Left="5"
                                                    Canvas.Top="205"
                                                    Width="100"
                                                    ItemsSource="{Binding SelectedXdPokespot.LevelOptions}"
                                                    SelectedItem="{Binding SelectedXdPokespot.MinLevel, Mode=TwoWay}"
                                                    MaxDropDownHeight="260">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat='Lv. {0}'}" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </controls:LegacyPokemonComboBox>
                    <controls:LegacyPokemonComboBox Classes="XdPickerField"
                                                    Canvas.Left="155"
                                                    Canvas.Top="205"
                                                    Width="95"
                                                    ItemsSource="{Binding SelectedXdPokespot.LevelOptions}"
                                                    SelectedItem="{Binding SelectedXdPokespot.MaxLevel, Mode=TwoWay}"
                                                    MaxDropDownHeight="260">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat='Lv. {0}'}" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </controls:LegacyPokemonComboBox>

                    <TextBlock Canvas.Left="5" Canvas.Top="250" Width="105" Text="Encounter Chance" Classes="XdLabel" TextAlignment="Center"/>
                    <TextBlock Canvas.Left="153" Canvas.Top="250" Width="100" Text="Steps Per Snack" Classes="XdLabel" TextAlignment="Center"/>
                    <TextBox Classes="XdMiniInput" Canvas.Left="5" Canvas.Top="275" Width="100" Text="{Binding SelectedXdPokespot.EncounterPercentage, Mode=TwoWay}"/>
                    <TextBox Classes="XdMiniInput" Canvas.Left="155" Canvas.Top="275" Width="90" Text="{Binding SelectedXdPokespot.StepsPerSnack, Mode=TwoWay}"/>

                    <Button Classes="XdSave"
                            Content="Save"
                            Width="80"
                            Height="21"
                            Command="{Binding SaveXdPokespotCommand}"
                            Canvas.Left="90"
                            Canvas.Top="306"/>
                </Canvas>
            </Border>
        </Grid>
    </Grid>
</UserControl>
