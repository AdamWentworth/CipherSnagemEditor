<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.XdPokespotEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="TextBox.XdField">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.XdSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBlock.XdLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.XdSave">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,*" Background="#303030">
        <Border Background="#222222" BorderBrush="#111111" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="XdSearch"
                         Text="{Binding XdPokespotSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"/>
                <ListBox Grid.Row="1"
                         Classes="LegacySidebarList"
                         ItemsSource="{Binding XdPokespotEntries}"
                         SelectedItem="{Binding SelectedXdPokespot, Mode=TwoWay}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:XdPokespotEntryViewModel">
                            <Border Height="50"
                                    Cursor="Hand"
                                    Background="{Binding FallbackBrush}"
                                    BorderBrush="{Binding SelectionBorderBrush}"
                                    BorderThickness="{Binding SelectionBorderThickness}">
                                <Grid ColumnDefinitions="50,*" ClipToBounds="True">
                                    <Image Grid.ColumnSpan="2" Source="{Binding TypeImage}" Stretch="Fill" Opacity="{Binding TypeImageOpacity}"/>
                                    <Image Source="{Binding FaceImage}" Width="50" Height="50" Stretch="Uniform"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RowText}"
                                               Foreground="#000000"
                                               FontSize="12"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="*,32" Margin="10">
            <Border Background="#303030" BorderBrush="#545454" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid RowDefinitions="112,30,30,30,30,30" ColumnDefinitions="120,*" ColumnSpacing="12" RowSpacing="9">
                    <Image Grid.RowSpan="2" Source="{Binding SelectedXdPokespot.BodyImage}" Stretch="Uniform" Width="96" Height="96" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedXdPokespot.Encounter.SpeciesName}" Foreground="#FFFFFF" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedXdPokespot.Encounter.SpotName, StringFormat='Pokespot: {0}'}" Foreground="#CFCFCF" FontSize="12"/>

                    <TextBlock Grid.Row="2" Text="Species:" Classes="XdLabel"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdPokespot.Encounter.SpeciesId, StringFormat='{}{0}'}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="3" Text="Min Level:" Classes="XdLabel"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdPokespot.Encounter.MinLevel}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="4" Text="Max Level:" Classes="XdLabel"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdPokespot.Encounter.MaxLevel}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="5" Text="Chance:" Classes="XdLabel"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Classes="XdField" Text="{Binding SelectedXdPokespot.Encounter.EncounterPercentage, StringFormat='{}{0}%'}" IsReadOnly="True"/>
                </Grid>
            </Border>

            <Button Grid.Row="1" Classes="XdSave" Content="Save" Width="100" Height="20" IsEnabled="False" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</UserControl>
