<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CipherSnagemEditor.App.Controls"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.CollisionViewerView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="TextBox.LegacyCollisionSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4,4,3"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBox.LegacyCollisionSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyCollisionSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="TextBlock.LegacyCollisionRowText">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="MaxLines" Value="2"/>
        </Style>
        <Style Selector="Border.LegacyCollisionRow:pointerover">
            <Setter Property="Opacity" Value="0.88"/>
        </Style>
        <Style Selector="ComboBox.LegacyCollisionCombo">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.LegacyCollisionStatus">
            <Setter Property="Foreground" Value="#101010"/>
            <Setter Property="Background" Value="#80B8B8B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,640"
          Width="840"
          Height="480"
          Background="#303030">
        <Border Grid.Column="0" Background="#000000">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyCollisionSearch"
                         Text="{Binding CollisionSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent">
                    <ItemsControl ItemsSource="{Binding CollisionFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CollisionFileEntryViewModel">
                                <Border Classes="LegacyCollisionRow"
                                        PointerPressed="CollisionFilePointerPressed"
                                        Cursor="Hand"
                                        Height="50"
                                        HorizontalAlignment="Stretch"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="{Binding SelectionBorderBrush}"
                                        BorderThickness="{Binding SelectionBorderThickness}">
                                    <TextBlock Classes="LegacyCollisionRowText"
                                               Text="{Binding RowText}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="1"
                Width="640"
                Height="480"
                Background="#B8B8B8">
            <controls:CollisionRenderView CollisionData="{Binding SelectedCollisionData}"
                                          HighlightInteraction="{Binding SelectedCollisionInteractionValue}"
                                          HighlightSection="{Binding SelectedCollisionSectionValue}"
                                          Canvas.Left="0"
                                          Canvas.Top="0"
                                          Width="640"
                                          Height="480"/>
            <controls:LegacyPokemonComboBox Classes="LegacyCollisionCombo"
                                            ItemsSource="{Binding CollisionInteractionOptions}"
                                            SelectedItem="{Binding SelectedCollisionInteraction, Mode=TwoWay}"
                                            Canvas.Left="8"
                                            Canvas.Top="7"
                                            Width="120"
                                            Height="20"
                                            MaxDropDownHeight="260"/>
            <controls:LegacyPokemonComboBox Classes="LegacyCollisionCombo"
                                            ItemsSource="{Binding CollisionSectionOptions}"
                                            SelectedItem="{Binding SelectedCollisionSection, Mode=TwoWay}"
                                            Canvas.Left="512"
                                            Canvas.Top="7"
                                            Width="120"
                                            Height="20"
                                            MaxDropDownHeight="260"/>
            <TextBlock Classes="LegacyCollisionStatus"
                       Text="{Binding CollisionStatus}"
                       Canvas.Left="8"
                       Canvas.Top="448"
                       Width="624"
                       Height="24"/>
        </Canvas>
    </Grid>
</UserControl>
