<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.TableEditorView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False"
             FontFamily="Arial"
             Background="#303030">
    <UserControl.Styles>
        <Style Selector="TextBox.LegacyTableSearch">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="PlaceholderForeground" Value="#A8A8A8"/>
        </Style>
        <Style Selector="TextBox.LegacyTableSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyTableSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="Border.LegacyTablePanel">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.LegacyTableTitle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBox.LegacyTableDetails">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#545454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="CaretBrush" Value="#E6E6E6"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
        </Style>
        <Style Selector="TextBox.LegacyTableDetails:pointerover">
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="CaretBrush" Value="#E6E6E6"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyTableDetails:focus">
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="CaretBrush" Value="#E6E6E6"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="Button.LegacyTableButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.LegacyTableButton:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="200,10,350"
          Width="560"
          Height="566"
          Background="#303030">
        <Border Grid.Column="0" Background="#222222">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyTableSearch"
                         Text="{Binding TableEditorSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         IsTabStop="False"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Visible">
                    <ItemsControl ItemsSource="{Binding TableEditorEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TableEditorEntryViewModel">
                                <Border PointerPressed="TableEditorPointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="{Binding SelectionBorderBrush}"
                                        BorderThickness="{Binding SelectionBorderThickness}">
                                    <TextBlock Text="{Binding Name}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="#000000"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxLines="2"
                                               Margin="8,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas Grid.Column="2"
                Width="350"
                Height="566"
                Background="#303030">
            <Border Classes="LegacyTablePanel"
                    Canvas.Left="0"
                    Canvas.Top="10"
                    Width="340"
                    Height="546">
                <Canvas Width="340" Height="546">
                    <Image Source="/Assets/Images/PokeBalls/ball-red.png"
                           Canvas.Left="120"
                           Canvas.Top="20"
                           Width="100"
                           Height="100"
                           Stretch="Uniform"/>
                    <TextBlock Classes="LegacyTableTitle"
                               Text="{Binding SelectedTableEditorName}"
                               Canvas.Left="18"
                               Canvas.Top="140"
                               Width="304"
                               Height="32"/>
                    <TextBox Classes="LegacyTableDetails"
                             Text="{Binding SelectedTableEditorDetails, Mode=OneWay}"
                             Canvas.Left="20"
                             Canvas.Top="192"
                             Width="300"
                             Height="150"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                    <Button Classes="LegacyTableButton"
                            Content="Encode as editable JSON"
                            Command="{Binding EncodeTableEditorCommand}"
                            IsEnabled="{Binding HasSelectedTableEditorEntry}"
                            Canvas.Left="50"
                            Canvas.Top="358"
                            Width="240"
                            Height="21"/>
                    <Button Classes="LegacyTableButton"
                            Content="Decode edited JSON"
                            Command="{Binding DecodeTableEditorCommand}"
                            IsEnabled="{Binding HasSelectedTableEditorEntry}"
                            Canvas.Left="50"
                            Canvas.Top="399"
                            Width="240"
                            Height="21"/>
                    <Button Classes="LegacyTableButton"
                            Content="Document as text files for reference"
                            Command="{Binding DocumentTableEditorCommand}"
                            IsEnabled="{Binding HasSelectedTableEditorEntry}"
                            Canvas.Left="50"
                            Canvas.Top="440"
                            Width="240"
                            Height="21"/>
                    <Button Classes="LegacyTableButton"
                            Content="Edit (coming soon)"
                            Command="{Binding EditTableEditorCommand}"
                            IsEnabled="{Binding HasSelectedTableEditorEntry}"
                            Canvas.Left="50"
                            Canvas.Top="481"
                            Width="240"
                            Height="21"/>
                </Canvas>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
