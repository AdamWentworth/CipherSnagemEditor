<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CipherSnagemEditor.App.Controls"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.TrainerEditorView"
             x:DataType="vm:MainWindowViewModel"
             FontFamily="Arial"
             Background="#242424">
    <UserControl.Styles>
        <Style Selector="Button.LegacyIsoButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.LegacyPokemonField">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="3,0,2,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyPokemonField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="Padding" Value="3,0"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyPokemonField:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>
        <Style Selector="TextBox.LegacyPokemonField:focus">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#8A8A8A"/>
        </Style>
        <Style Selector="ComboBox.LegacyHeaderField">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="BorderBrush" Value="#C7AEFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyHeaderField">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="BorderBrush" Value="#C7AEFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyHeaderField:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D4C1FF"/>
        </Style>
        <Style Selector="TextBox.LegacyHeaderField:focus">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#E1D2FF"/>
        </Style>
        <Style Selector="Border.LegacyHeaderField">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="BorderBrush" Value="#C7AEFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="TextBlock.LegacyHeaderText">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:focus-within">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="246,*">
        <Border Grid.Column="0"
                Background="#222222"
                BorderBrush="#111111"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyTrainerSearch"
                         Text="{Binding TrainerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         PlaceholderForeground="#D8D8D8"
                         Height="28"
                         Margin="4,4"
                         Padding="8,3"
                         FontSize="12"
                         Background="#333333"
                         Foreground="#FFFFFF"
                         CaretBrush="#FFFFFF"
                         SelectionBrush="#80ACFF"
                         BorderBrush="#5C5C5C"
                         BorderThickness="1"/>
                <ListBox Grid.Row="1"
                         Classes="LegacySidebarList"
                         ItemsSource="{Binding Trainers}"
                         SelectedItem="{Binding SelectedTrainer, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrainerEntryViewModel">
                                <Border PointerPressed="TrainerPointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="#111111"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="50,*">
                                        <Image Source="{Binding TrainerImage}"
                                               Width="50"
                                               Height="50"
                                               Stretch="Uniform"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RowText}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#000000"
                                                   TextWrapping="NoWrap"
                                                   TextAlignment="Center"
                                                   MaxLines="2"
                                                   Margin="4,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              RowDefinitions="80,*"
              Background="#242424">
            <Border Background="{Binding TrainerDetailBackgroundBrush}"
                    BorderBrush="#A77AF4"
                    BorderThickness="0">
                <Grid ColumnDefinitions="80,150,150,100,150,100,*"
                      RowDefinitions="25,25"
                      Margin="20,10,0,10"
                      ColumnSpacing="10"
                      RowSpacing="10">
                    <Border Width="60"
                            Height="60"
                            Background="#FFFFFF"
                            BorderBrush="#000000"
                            BorderThickness="1"
                            Grid.RowSpan="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <Image Source="{Binding SelectedTrainer.TrainerImage}"
                               Stretch="Uniform"/>
                    </Border>

                    <Border Grid.Column="1"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerClass}"/>
                    </Border>
                    <Border Grid.Column="2"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerName}"/>
                    </Border>
                    <Border Grid.Column="3"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerAi}"/>
                    </Border>
                    <Border Grid.Column="4"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerBattleStyle}"/>
                    </Border>
                    <Border Grid.Column="5"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerBattleId}"/>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerModel}"/>
                    </Border>
                    <Border Grid.Row="1"
                            Grid.Column="3"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerBgm}"/>
                    </Border>
                    <Border Grid.Row="1"
                            Grid.Column="4"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerBattleType}"/>
                    </Border>
                    <TextBlock Grid.Row="1"
                               Grid.Column="6"
                               Text="{Binding SelectedTrainerStringIds}"
                               Foreground="#FFFFFF"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="#242424"
                    BorderThickness="0"
                    Background="#242424">
                <Grid RowDefinitions="*,30"
                      Margin="10">
                    <ItemsControl ItemsSource="{Binding SelectedTrainerPokemon}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="2" Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrainerPokemonSlotViewModel">
                                <Border Background="{Binding BackgroundBrush}"
                                        BorderBrush="#3C3C3C"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Margin="5"
                                        Opacity="{Binding Opacity}"
                                        ClipToBounds="True">
                                    <Grid RowDefinitions="20,20,20,20,20,16,12,16,21,13,16"
                                          ColumnDefinitions="64,*,*"
                                          Margin="4"
                                          ColumnSpacing="6"
                                          RowSpacing="2"
                                          ClipToBounds="True">
                                        <TextBlock Text="{Binding DeckIndexText}"
                                                   Foreground="{Binding TextBrush}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <controls:LegacyPokemonComboBox Grid.Column="1"
                                                  Grid.ColumnSpan="2"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  IsVisible="{Binding ShowShadowPicker}"
                                                  ItemsSource="{Binding ShadowOptions}"
                                                  SelectedItem="{Binding SelectedShadow, Mode=TwoWay}"
                                                  MaxDropDownHeight="260"/>
                                        <Border Grid.Row="1"
                                                Grid.RowSpan="3"
                                                IsVisible="{Binding IsSet}"
                                                Width="64"
                                                Height="64"
                                                Background="{Binding ImageBackgroundBrush}"
                                                BorderBrush="{Binding FieldBorderBrush}"
                                                BorderThickness="1">
                                            <Image Source="{Binding BodyImage}"
                                                   Classes="PokemonBodyImage"
                                                   Stretch="Uniform"/>
                                        </Border>
                                        <controls:LegacyPokemonComboBox Grid.Row="1"
                                                  Grid.RowSpan="3"
                                                  Grid.ColumnSpan="3"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  IsVisible="{Binding IsEmpty}"
                                                  ItemsSource="{Binding SpeciesOptions}"
                                                  SelectedItem="{Binding SelectedSpecies, Mode=TwoWay}"
                                                  MaxDropDownHeight="260"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  Margin="34,0"/>

                                        <controls:LegacyPokemonComboBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  IsVisible="{Binding IsSet}"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  ItemsSource="{Binding LevelOptions}"
                                                  SelectedItem="{Binding Level, Mode=TwoWay}"
                                                  MaxDropDownHeight="260">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StringFormat='Lv. {0}'}"
                                                               HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </controls:LegacyPokemonComboBox>
                                        <controls:LegacyPokemonComboBox Grid.Row="1"
                                                  Grid.Column="2"
                                                  IsVisible="{Binding IsSet}"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  ItemsSource="{Binding SpeciesOptions}"
                                                  SelectedItem="{Binding SelectedSpecies, Mode=TwoWay}"
                                                  MaxDropDownHeight="260"/>

                                        <controls:LegacyPokemonComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  IsVisible="{Binding IsSet}"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  ItemsSource="{Binding AbilityOptions}"
                                                  SelectedItem="{Binding SelectedAbility, Mode=TwoWay}"/>
                                        <controls:LegacyPokemonComboBox Grid.Row="2"
                                                  Grid.Column="2"
                                                  IsVisible="{Binding IsSet}"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  ItemsSource="{Binding ItemOptions}"
                                                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                  MaxDropDownHeight="260"/>

                                        <controls:LegacyPokemonComboBox Grid.Row="3"
                                                  Grid.Column="1"
                                                  IsVisible="{Binding IsSet}"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  ItemsSource="{Binding NatureOptions}"
                                                  SelectedItem="{Binding SelectedNature, Mode=TwoWay}"/>
                                        <controls:LegacyPokemonComboBox Grid.Row="3"
                                                  Grid.Column="2"
                                                  IsVisible="{Binding IsSet}"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  ItemsSource="{Binding GenderOptions}"
                                                  SelectedItem="{Binding SelectedGender, Mode=TwoWay}"/>

                                        <controls:LegacyPokemonComboBox Grid.Row="4"
                                                  IsVisible="{Binding IsSet}"
                                                  Classes="LegacyPokemonField"
                                                  Background="{Binding FieldBackgroundBrush}"
                                                  BorderBrush="{Binding FieldBorderBrush}"
                                                  Foreground="{Binding TextBrush}"
                                                  ItemsSource="{Binding PokeballOptions}"
                                                  SelectedItem="{Binding SelectedPokeball, Mode=TwoWay}"
                                                  MaxDropDownHeight="260"/>
                                        <Grid Grid.Row="4"
                                              Grid.Column="1"
                                              Grid.ColumnSpan="2"
                                              IsVisible="{Binding IsSet}"
                                              ColumnDefinitions="*,*"
                                              ColumnSpacing="8">
                                            <TextBlock Text="IVs"
                                                       Foreground="{Binding TextBrush}"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Bottom"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Happiness"
                                                       Foreground="{Binding TextBrush}"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Bottom"/>
                                        </Grid>
                                        <Grid Grid.Row="5"
                                              Grid.Column="1"
                                              Grid.ColumnSpan="2"
                                              IsVisible="{Binding IsSet}"
                                              ColumnDefinitions="*,*"
                                              ColumnSpacing="8">
                                            <Border Background="{Binding FieldBackgroundBrush}"
                                                    BorderBrush="{Binding FieldBorderBrush}"
                                                    BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField"
                                                         Background="{Binding FieldBackgroundBrush}"
                                                         BorderBrush="{Binding FieldBorderBrush}"
                                                         Foreground="{Binding TextBrush}"
                                                         Text="{Binding Iv, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Column="1"
                                                    Background="{Binding FieldBackgroundBrush}"
                                                    BorderBrush="{Binding FieldBorderBrush}"
                                                    BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField"
                                                         Background="{Binding FieldBackgroundBrush}"
                                                         BorderBrush="{Binding FieldBorderBrush}"
                                                         Foreground="{Binding TextBrush}"
                                                         Text="{Binding Happiness, Mode=TwoWay}"/>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="6"
                                              IsVisible="{Binding IsSet}"
                                              Grid.ColumnSpan="3"
                                              ColumnDefinitions="42,42,42,42,42,42"
                                              ColumnSpacing="6"
                                              HorizontalAlignment="Center">
                                            <TextBlock Text="HP" Foreground="{Binding TextBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Atk" Foreground="{Binding TextBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="Def" Foreground="{Binding TextBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="Sp.A" Foreground="{Binding TextBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="Sp.D" Foreground="{Binding TextBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="Speed" Foreground="{Binding TextBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="7"
                                              IsVisible="{Binding IsSet}"
                                              Grid.ColumnSpan="3"
                                              ColumnDefinitions="42,42,42,42,42,42"
                                              ColumnSpacing="6"
                                              HorizontalAlignment="Center">
                                            <Border Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding HpEv, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Column="1" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding AttackEv, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Column="2" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding DefenseEv, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Column="3" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding SpecialAttackEv, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Column="4" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding SpecialDefenseEv, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Column="5" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding SpeedEv, Mode=TwoWay}"/>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="8"
                                              Grid.ColumnSpan="3"
                                              IsVisible="{Binding IsSet}"
                                              ColumnDefinitions="*,*,*,*"
                                              ColumnSpacing="7"
                                              ClipToBounds="True">
                                            <controls:LegacyPokemonComboBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" FontSize="8" ItemsSource="{Binding MoveOptions}" SelectedItem="{Binding SelectedMove1, Mode=TwoWay}" MaxDropDownHeight="260"/>
                                            <controls:LegacyPokemonComboBox Grid.Column="1" Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" FontSize="8" ItemsSource="{Binding MoveOptions}" SelectedItem="{Binding SelectedMove2, Mode=TwoWay}" MaxDropDownHeight="260"/>
                                            <controls:LegacyPokemonComboBox Grid.Column="2" Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" FontSize="8" ItemsSource="{Binding MoveOptions}" SelectedItem="{Binding SelectedMove3, Mode=TwoWay}" MaxDropDownHeight="260"/>
                                            <controls:LegacyPokemonComboBox Grid.Column="3" Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" FontSize="8" ItemsSource="{Binding MoveOptions}" SelectedItem="{Binding SelectedMove4, Mode=TwoWay}" MaxDropDownHeight="260"/>
                                        </Grid>
                                        <Grid Grid.Row="9"
                                              Grid.RowSpan="2"
                                              Grid.ColumnSpan="3"
                                              IsVisible="{Binding ShowShadowFields}"
                                              RowDefinitions="11,16"
                                              ColumnDefinitions="80,80,80,80"
                                              ColumnSpacing="7"
                                              RowSpacing="0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Top">
                                            <TextBlock Text="Heart Gauge" Foreground="{Binding TextBrush}" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="First TID" Foreground="{Binding TextBrush}" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="Alternate TID" Foreground="{Binding TextBrush}" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="3" Text="Catch rate" Foreground="{Binding TextBrush}" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Row="1" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding ShadowHeartGauge, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Row="1" Grid.Column="1" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding ShadowFirstTrainerId, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Row="1" Grid.Column="2" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding ShadowAlternateFirstTrainerId, Mode=TwoWay}"/>
                                            </Border>
                                            <Border Grid.Row="1" Grid.Column="3" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" BorderThickness="1">
                                                <TextBox Classes="LegacyPokemonField" Background="{Binding FieldBackgroundBrush}" BorderBrush="{Binding FieldBorderBrush}" Foreground="{Binding TextBrush}" Text="{Binding ShadowCatchRate, Mode=TwoWay}"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Grid.Row="1"
                            Classes="LegacyIsoButton"
                            Width="100"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Content="Save"
                            Command="{Binding SaveTrainerCommand}"
                            Foreground="#FFFFFF"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
