<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CipherSnagemEditor.App.Controls"
             xmlns:views="using:CipherSnagemEditor.App.Views"
             xmlns:vm="using:CipherSnagemEditor.App.ViewModels"
             x:Class="CipherSnagemEditor.App.Views.TrainerEditorView"
             x:DataType="vm:MainWindowViewModel"
             FontFamily="Arial"
             Background="#242424">
    <UserControl.Styles>
        <Style Selector="Button.LegacyIsoButton">
            <Setter Property="Background" Value="#6E6E6E"/>
            <Setter Property="BorderBrush" Value="#7B7B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.LegacyPokemonField">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="3,0,2,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyPokemonField">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="Padding" Value="3,0"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="BorderBrush" Value="#747474"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyPokemonField:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>
        <Style Selector="TextBox.LegacyPokemonField:focus">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#8A8A8A"/>
        </Style>
        <Style Selector="ComboBox.LegacyHeaderField">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="BorderBrush" Value="#C7AEFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyHeaderField">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="BorderBrush" Value="#C7AEFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.LegacyHeaderField:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D4C1FF"/>
        </Style>
        <Style Selector="TextBox.LegacyHeaderField:focus">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#E1D2FF"/>
        </Style>
        <Style Selector="Border.LegacyHeaderField">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Background" Value="#B895FF"/>
            <Setter Property="BorderBrush" Value="#C7AEFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="TextBlock.LegacyHeaderText">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:pointerover">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:focus">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#5C5C5C"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
        <Style Selector="TextBox.LegacyTrainerSearch:focus-within">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#80ACFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="246,*">
        <Border Grid.Column="0"
                Background="#222222"
                BorderBrush="#111111"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBox Classes="LegacyTrainerSearch"
                         Text="{Binding TrainerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         PlaceholderForeground="#D8D8D8"
                         Height="28"
                         Margin="4,4"
                         Padding="8,3"
                         FontSize="12"
                         Background="#333333"
                         Foreground="#FFFFFF"
                         CaretBrush="#FFFFFF"
                         SelectionBrush="#80ACFF"
                         BorderBrush="#5C5C5C"
                         BorderThickness="1"/>
                <ListBox Grid.Row="1"
                         Classes="LegacySidebarList"
                         ItemsSource="{Binding Trainers}"
                         SelectedItem="{Binding SelectedTrainer, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrainerEntryViewModel">
                                <Border PointerPressed="TrainerPointerPressed"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Height="50"
                                        Background="{Binding BackgroundBrush}"
                                        BorderBrush="#111111"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="50,*">
                                        <Image Source="{Binding TrainerImage}"
                                               Width="50"
                                               Height="50"
                                               Stretch="Uniform"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RowText}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#000000"
                                                   TextWrapping="NoWrap"
                                                   TextAlignment="Center"
                                                   MaxLines="2"
                                                   Margin="4,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              RowDefinitions="80,*"
              Background="#242424">
            <Border Background="{Binding TrainerDetailBackgroundBrush}"
                    BorderBrush="#A77AF4"
                    BorderThickness="0">
                <Grid ColumnDefinitions="80,150,150,100,150,100,*"
                      RowDefinitions="25,25"
                      Margin="20,10,0,10"
                      ColumnSpacing="10"
                      RowSpacing="10">
                    <Border Width="60"
                            Height="60"
                            Background="#FFFFFF"
                            BorderBrush="#000000"
                            BorderThickness="1"
                            Grid.RowSpan="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <Image Source="{Binding SelectedTrainer.TrainerImage}"
                               Stretch="Uniform"/>
                    </Border>

                    <Border Grid.Column="1"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerClass}"/>
                    </Border>
                    <Border Grid.Column="2"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerName}"/>
                    </Border>
                    <Border Grid.Column="3"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerAi}"/>
                    </Border>
                    <Border Grid.Column="4"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerBattleStyle}"/>
                    </Border>
                    <Border Grid.Column="5"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerBattleId}"/>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerModel}"/>
                    </Border>
                    <Border Grid.Row="1"
                            Grid.Column="3"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerBgm}"/>
                    </Border>
                    <Border Grid.Row="1"
                            Grid.Column="4"
                            Classes="LegacyHeaderField">
                        <TextBlock Classes="LegacyHeaderText"
                                   Text="{Binding SelectedTrainerBattleType}"/>
                    </Border>
                    <TextBlock Grid.Row="1"
                               Grid.Column="6"
                               Text="{Binding SelectedTrainerStringIds}"
                               Foreground="#FFFFFF"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="#242424"
                    BorderThickness="0"
                    Background="#242424">
                <Grid RowDefinitions="*,30"
                      Margin="10">
                    <ItemsControl ItemsSource="{Binding SelectedTrainerPokemon}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="2" Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrainerPokemonSlotViewModel">
                                <views:TrainerPokemonSlotView/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Grid.Row="1"
                            Classes="LegacyIsoButton"
                            Width="100"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Content="Save"
                            Command="{Binding SaveTrainerCommand}"
                            Foreground="#FFFFFF"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
